      <column caption='Heart Disease Label' datatype='string' name='[Calculation_1508317912928256]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [target] = 0 THEN &quot;Heart Disease&quot;&#13;&#10;ELSE &quot;No Heart Disease&quot;&#13;&#10;END' />
      </column>
      <column caption='Gender Level' datatype='string' name='[Calculation_1508317914226690]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [sex] = 1 THEN &quot;Male&quot;&#13;&#10;ELSE &quot;Female&quot;&#13;&#10;END' />
      </column>
      <column caption='Chest Pain Type' datatype='string' name='[Calculation_1508317914836995]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [cp] = 0 THEN &quot;Non-anginal&quot;&#13;&#10;ELSEIF [cp] = 1 THEN &quot;Atypical&quot;&#13;&#10;ELSEIF [cp] =2 THEN &quot;Asymptomatic&quot;&#13;&#10;ELSE &quot;Typical&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1508317915656196]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt; 40 THEN &quot;&lt;40&quot;&#13;&#10;ELSEIF [age] &lt;= 50 THEN &quot;40-50&quot;&#13;&#10;ELSEIF [age] &lt;= 60 THEN &quot;51-60&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
      <column caption='Exercice Practice' datatype='string' name='[Calculation_1508317916033029]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [exang] =0 THEN &quot;No&quot;&#13;&#10;ELSE &quot;Yes&quot;&#13;&#10;END' />
      </column>
      <column caption='High Cholesterol Flag' datatype='string' name='[Calculation_1508317916340230]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [chol] &gt; 240 THEN &quot;High Cholesterol&quot;&#13;&#10;ELSE &quot;Normal Cholesterol&quot;&#13;&#10;END' />
      </column>
